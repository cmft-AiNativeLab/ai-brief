# 复制本文件为 .env 并填入真实值；.env 已被 .gitignore，不会提交到仓库。
# 切勿把真实 key 写进 .env.example 或任何会 push 的文件！

AI_BRIEF_API_KEY=sk-你的key填这里
AI_BRIEF_BASE_URL=https://newapi.ai-native-lab.com
# 模型须是中转「有可用渠道」的（用 GET /v1/models 查）；示例可选：
#   aly-qwen3.7-max / qwen3.7-max / deepseek-v4-pro / aly-glm-5.1
AI_BRIEF_MODEL=aly-qwen3.7-max
